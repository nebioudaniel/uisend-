generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  botToken   String?
  telegramId String?
  tasks      Task[]
}

model Task {
  id                String    @id @default(cuid())
  userId            String
  title             String
  description       String?
  status            String    @default("pending")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  category          String?
  date              DateTime
  duration          Int
  finishedAt        DateTime?
  frequency         String    @default("once")
  lastPingAt        DateTime?
  startedAt         DateTime?
  middleConfirmedAt DateTime?
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}
